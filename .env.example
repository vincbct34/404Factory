# Resend Configuration (server-side only — no VITE_ prefix, never bundled to client)
# Get your API key from: https://resend.com/api-keys
# Verify 404-factory.com in Resend (Domains > Add Domain, add the DNS records
# at your registrar) — no mailbox needed, the address below can be anything @404-factory.com.

RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=contact@404-factory.com
RESEND_FROM_NAME=404Factory
CONTACT_RECEIVER_EMAIL=factory404@outlook.fr

# MyVouch API Configuration (server-side only — no VITE_ prefix, never bundled
# to the client). Account-scoped bearer token; fetched via /api/endorsements.
MYVOUCH_API_URL=https://www.myvouch.fr/api/me/endorsements
MYVOUCH_API_TOKEN=your_myvouch_api_token_here
